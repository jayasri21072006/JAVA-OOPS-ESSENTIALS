Interface for multiple inheritance





interface Father {

   abstract void call();
}

interface Mother {

    abstract void calling();
}

class Interfaces implements Father, Mother {

    public void call() {
        System.out.println("Calling Father");
    }

    public void calling() {
        System.out.println("Calling Mother");
    }
}

public class Main {

    public static void main(String[] args) {

        Interfaces obj = new Interfaces();

        obj.call();
        obj.calling();
    }
}




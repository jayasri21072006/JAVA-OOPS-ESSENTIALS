Make a Distinct Digit Array
Difficulty: BasicAccuracy: 49.37%Submissions: 19K+Points: 1Average Time: 10m
Given an array nums of positive integers of size N. Find all distinct digits present in nums.
 

Example 1:

Input: nums = [131, 11, 48]
Output: 1 3 4 8
Explanation: 1, 3, 4, and 8 are only distinct
digits that can be extracted from the numbers
of the arr






class Solution {
    public int[] common_digits(int[] nums) {
        
        boolean[] seen = new boolean[10];
        
        // Step 1: extract digits
        for(int val : nums) {
            while(val > 0) {
                int digit = val % 10;
                seen[digit] = true;
                val = val / 10;
            }
        }
        
        // Step 2: count digits
        int count = 0;
        for(int i = 0; i < seen.length; i++) {
            if(seen[i]) count++;
        }
        
        // Step 3: create array
        int[] arrs = new int[count];
        
        // Step 4: fill array
        int index = 0;
        for(int i = 0; i < seen.length; i++) {
            if(seen[i]) {
                arrs[index++] = i;
            }
        }
        
        return arrs;
    }
}
